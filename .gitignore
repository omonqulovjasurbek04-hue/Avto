# Local toolchain (downloaded Dart SDK) - not part of the repo
.toolchain/

# Build outputs
build/
frontend/app/build/
frontend/editor/dist/
frontend/editor/node_modules/
node_modules/

# Dart
.dart_tool/
.packages
# Libraries do not pin; the shipped application does.
engine_dart/pubspec.lock

# App and viewer assets are synced from /content by tools/sync_content.js
frontend/app/assets/content/
frontend/editor/public/content/

# The browser viewer's engine bundle, built by tools/build_viewer.js
frontend/editor/public/engine.js
frontend/editor/public/engine.js.map
frontend/editor/public/engine.js.deps

# JS monorepo (Express + React + Expo). node_modules already ignored above.
*/node_modules/

# Local / runtime only:
backend/server/data/*
!backend/server/data/.gitkeep
frontend/web/dist/
frontend/mobile/.expo/

# Synced content copies — duplicates of the canonical /content (served via the
# API), regenerated by tools/sync_content.js.
backend/server/public/content/
frontend/web/public/content/
frontend/mobile/assets/content/

# The engine bundle IS committed for the JS stack (shared/engine-js/engine.js,
# server/public/engine.js, web/public/engine.js) so a clone runs without the
# Dart toolchain. Only the mobile copy is unused (it loads from the server).
frontend/mobile/assets/engine.js

# OS noise
Thumbs.db
.DS_Store
