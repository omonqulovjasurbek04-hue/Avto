# ============================================
# AVTO (YHQ) Backend — Environment Variables
# ============================================
# Ushbu faylni .env ga nusxalang va qiymatlarni o'zgartiring:
#   cp .env.example .env

# ---------- Database ----------
# PostgreSQL ulanish URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/avto_db"

# ---------- JWT ----------
# Productionda ALBATTA o'zgartiring! Bo'sh qoldirilsa dev rejimida
# avtomatik generatsiya qilinadi (faqat bitta instance uchun ishlaydi).
JWT_SECRET=

# Token muddati (masalan: 7d, 24h, 30m)
JWT_EXPIRES_IN="7d"

# ---------- Server ----------
PORT=4000
NODE_ENV=development

# CORS: ruxsat berilgan originlar (vergul bilan ajratilgan)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Rate Limiting ----------
# Oyna davomiyligi (ms). Default: 15 daqiqa
RATE_LIMIT_WINDOW_MS=900000
# Oyna ichida maksimal so'rovlar soni
RATE_LIMIT_MAX=100
